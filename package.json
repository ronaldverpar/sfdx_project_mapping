{
  "name": "sf-dependency-analysis",
  "displayName": "SF Dependency Analysis",
  "description": "Visual dependency graph for Salesforce DX projects — map Apex classes, LWC components, triggers, and identify unused code.",
  "version": "0.1.1",
  "publisher": "sf-dependency-analysis",
  "repository": {
    "type": "git",
    "url": "https://github.com/ronaldverpar/sfdx_project_mapping"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "salesforce",
    "sfdx",
    "apex",
    "lwc",
    "dependency",
    "graph",
    "dead code"
  ],
  "activationEvents": [
    "workspaceContains:sfdx-project.json"
  ],
  "main": "./out/extension.js",
  "icon": "media/icon.png",
  "contributes": {
    "commands": [
      {
        "command": "sfDependencyAnalysis.showGraph",
        "title": "SF Analysis: Show Dependency Graph",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "sfDependencyAnalysis.refresh",
        "title": "SF Analysis: Refresh Dependency Graph",
        "icon": "$(refresh)"
      },
      {
        "command": "sfDependencyAnalysis.findUnused",
        "title": "SF Analysis: Find Unused Classes & Components"
      },
      {
        "command": "sfDependencyAnalysis.focusNode",
        "title": "SF Analysis: Focus on Class/Component"
      },
      {
        "command": "sfDependencyAnalysis.impactAnalysis",
        "title": "SF Analysis: Impact Analysis — What breaks if I change this?"
      },
      {
        "command": "sfDependencyAnalysis.findCycles",
        "title": "SF Analysis: Find Circular Dependencies"
      },
      {
        "command": "sfDependencyAnalysis.exportReport",
        "title": "SF Analysis: Export Dependency Report (JSON)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sf-dependency-analysis",
          "title": "SF Dependency Analysis",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "sf-dependency-analysis": [
        {
          "id": "sfDependencyAnalysis.unusedItems",
          "name": "Unused Classes & Components",
          "type": "tree"
        },
        {
          "id": "sfDependencyAnalysis.dependencies",
          "name": "Dependencies",
          "type": "tree"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "when": "resourceExtname == .cls || resourceExtname == .html",
          "command": "sfDependencyAnalysis.showGraph",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "sfDependencyAnalysis.refresh",
          "when": "view == sfDependencyAnalysis.unusedItems",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "SF Dependency Analysis",
      "properties": {
        "sfDependencyAnalysis.excludePatterns": {
          "type": "array",
          "default": [
            "**/node_modules/**",
            "**/.sfdx/**"
          ],
          "description": "Glob patterns for files to exclude from analysis."
        },
        "sfDependencyAnalysis.entryPoints": {
          "type": "array",
          "default": [],
          "description": "Classes/components to always consider 'used' (e.g., Schedulable, Batchable entry points)."
        },
        "sfDependencyAnalysis.includeTestClasses": {
          "type": "boolean",
          "default": false,
          "description": "Include test classes in the dependency graph."
        },
        "sfDependencyAnalysis.graphLayout": {
          "type": "string",
          "enum": [
            "force-directed",
            "hierarchical",
            "circular"
          ],
          "default": "force-directed",
          "description": "Default graph layout algorithm."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "jest"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {}
}
